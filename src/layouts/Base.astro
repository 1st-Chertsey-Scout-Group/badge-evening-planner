---
import '@fontsource-variable/nunito-sans/index.css'
import '@/styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Scout Badge Tracker',
  description = 'Browse Scouts badges, tick off requirements, and track your progress - saved in your browser.',
} = Astro.props

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-5xl items-center gap-2 px-4 py-3">
        <a href="/" class="flex items-center gap-2 font-bold text-scout-purple">
          <img src="/favicon.svg" alt="" width="28" height="28" />
          <span>Badge Tracker</span>
        </a>
      </div>
    </header>
    <slot />
  </body>
</html>
