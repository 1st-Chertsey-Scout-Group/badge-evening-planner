---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import Base from '@/layouts/Base.astro'
import BadgeChecklist from '@/components/BadgeChecklist'
import { resolveBadge } from '@/lib/resolve'
import { md } from '@/lib/markdown'
import { TYPE_LABEL } from '@/lib/badges'
import { ArrowLeft } from 'lucide-preact'

export async function getStaticPaths() {
  const badges = await getCollection('badges')
  return badges.map((badge) => ({ params: { slug: badge.id }, props: { badge } }))
}

const { badge } = Astro.props
const d = badge.data
const resolved = await resolveBadge(badge)
const tags = [...d.sections, ...d.settings, ...d.activityTypes]
---

<Base title={`${d.title} - Badge Tracker`} description={d.description}>
  <main class="mx-auto max-w-3xl px-4 py-8">
    <a href="/" class="inline-flex items-center gap-1 text-sm text-scout-purple hover:underline">
      <ArrowLeft size={16} /> All badges
    </a>

    <header class="mt-4 flex gap-5">
      <Image
        src={d.image.src}
        alt={d.image.alt}
        width={128}
        class="h-24 w-24 shrink-0 rounded-xl bg-white object-contain p-1"
      />
      <div>
        <p class="text-xs font-semibold tracking-wide text-scout-purple uppercase">
          {TYPE_LABEL[d.type]}
        </p>
        <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">{d.title}</h1>
        {d.description && <p class="mt-1 text-slate-600">{d.description}</p>}
        {
          tags.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-2">
              {tags.map((t) => (
                <li class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
                  {t}
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    {
      d.safetyAlert && (
        <aside class="mt-6 rounded-xl border border-scout-red/30 bg-scout-red/5 p-4">
          <p class="text-sm font-semibold text-scout-red">Safety</p>
          <div class="prose-notes mt-1 text-sm text-slate-700" set:html={md(d.safetyAlert)} />
        </aside>
      )
    }

    <section class="mt-8">
      <BadgeChecklist client:load badge={resolved} />
    </section>

    {
      d.tips.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Tips</h2>
          <ul class="space-y-3">
            {d.tips.map((tip) => (
              <li class="rounded-xl border border-slate-200 bg-white p-4">
                <p class="font-medium text-slate-800">{tip.title}</p>
                {tip.details && (
                  <div class="prose-notes mt-1 text-sm text-slate-600" set:html={md(tip.details)} />
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      d.outcomes.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Learning outcomes</h2>
          <ul class="space-y-2">
            {d.outcomes.map((o) => (
              <li class="rounded-lg bg-white p-3 ring-1 ring-slate-200">
                <span class="font-medium text-slate-800">{o.label}</span>
                {o.description && <span class="text-slate-600"> - {o.description}</span>}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      d.youthShapedSuggestions && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Youth-shaped ideas</h2>
          <div class="prose-notes text-sm text-slate-600" set:html={md(d.youthShapedSuggestions)} />
        </section>
      )
    }

    {
      d.relatedBadges.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Related badges</h2>
          <ul class="flex flex-wrap gap-2">
            {d.relatedBadges.map((r) => (
              <li>
                <a
                  href={r.url}
                  class="rounded-full bg-scout-purple/10 px-3 py-1 text-sm text-scout-purple-dark hover:bg-scout-purple/20"
                >
                  {r.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <footer class="mt-12 border-t border-slate-200 pt-6 text-sm text-slate-500">
      {d.supportedBy?.title && <p>Supported by {d.supportedBy.title}.</p>}
      <p class="mt-1">
        Version {d.versionDate}.{' '}
        <a
          href={d.sourceUrl}
          class="text-scout-purple hover:underline"
          target="_blank"
          rel="noopener"
        >
          Source on scouts.org.uk
        </a>
      </p>
    </footer>
  </main>
</Base>
