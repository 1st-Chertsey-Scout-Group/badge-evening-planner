---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import Base from '@/layouts/Base.astro'
import BadgeChecklist from '@/components/BadgeChecklist'
import BadgeBases from '@/components/BadgeBases'
import { getBadgeSlugs, resolveBadge, renderProse, leanModel } from '@/lib/resolve'
import { basesForBadge } from '@/lib/bases'
import { badgeHrefFor } from '@/lib/links'
import { PROSE } from '@/lib/prose'
import { TYPE_LABEL } from '@/lib/badges'
import { badgeVerdict, stageVerdicts, SUIT_META } from '@/lib/suitability'
import { ArrowLeft } from 'lucide-preact'

export async function getStaticPaths() {
  const badges = await getCollection('badges')
  return badges.map((badge) => ({ params: { slug: badge.id }, props: { badge } }))
}

const { badge } = Astro.props
const d = badge.data
const resolved = await resolveBadge(badge)
const lean = leanModel(resolved)
const verdict = badgeVerdict(lean)
const stageVs = stageVerdicts(lean)
const tags = [...d.sections, ...d.settings, ...d.activityTypes]

const safetyHtml = d.safetyAlert ? await renderProse(d.safetyAlert) : ''
const youthHtml = d.youthShapedSuggestions ? await renderProse(d.youthShapedSuggestions) : ''
const tips = await Promise.all(
  d.tips.map(async (t) => ({
    title: t.title,
    detailsHtml: t.details ? await renderProse(t.details) : '',
  })),
)

const bases = await basesForBadge(badge.id)

const slugs = await getBadgeSlugs()
const related = d.relatedBadges.map((r) => {
  const internal = badgeHrefFor(r.url, slugs)
  return { title: r.title, href: internal ?? r.url, external: internal === null }
})
---

<Base title={`${d.title} - Badge Tracker`} description={d.description}>
  <main class="mx-auto max-w-3xl px-4 py-8">
    <a href="/" class="inline-flex items-center gap-1 text-sm text-scout-purple hover:underline">
      <ArrowLeft size={16} /> All badges
    </a>

    <header class="mt-4 flex gap-5">
      <Image
        src={d.image.src}
        alt={d.image.alt}
        width={128}
        class="h-24 w-24 shrink-0 rounded-xl bg-white object-contain p-1"
      />
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <p class="text-xs font-semibold tracking-wide text-scout-purple uppercase">
            {TYPE_LABEL[d.type]}
          </p>
          <span
            class={`rounded-full px-2 py-0.5 text-xs font-semibold ${SUIT_META[verdict].chip}`}
            title="How achievable this badge is at our HQ"
          >
            {SUIT_META[verdict].label}
          </span>
        </div>
        <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">{d.title}</h1>
        {d.description && <p class="mt-1 text-slate-600">{d.description}</p>}
        {
          tags.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-2">
              {tags.map((t) => (
                <li class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
                  {t}
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </header>

    {
      d.safetyAlert && (
        <aside class="mt-6 rounded-xl border border-scout-red/30 bg-scout-red/5 p-4">
          <p class="text-sm font-semibold text-scout-red">Safety</p>
          <div class={`mt-1 ${PROSE}`} set:html={safetyHtml} />
        </aside>
      )
    }

    <section class="mt-8">
      <BadgeChecklist client:load badge={resolved} bases={bases} stageVerdicts={stageVs} />
    </section>

    {
      bases.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Bases for this badge</h2>
          <p class="mb-3 text-sm text-slate-600">
            Activities that tick off these requirements. Add them to your evening plan.
          </p>
          <BadgeBases client:load badgeSlug={badge.id} bases={bases} />
        </section>
      )
    }

    {
      d.tips.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Tips</h2>
          <ul class="space-y-3">
            {tips.map((tip) => (
              <li class="rounded-xl border border-slate-200 bg-white p-4">
                <p class="font-medium text-slate-800">{tip.title}</p>
                {tip.detailsHtml && <div class={`mt-1 ${PROSE}`} set:html={tip.detailsHtml} />}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      d.outcomes.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Learning outcomes</h2>
          <ul class="space-y-2">
            {d.outcomes.map((o) => (
              <li class="rounded-lg bg-white p-3 ring-1 ring-slate-200">
                <span class="font-medium text-slate-800">{o.label}</span>
                {o.description && <span class="text-slate-600"> - {o.description}</span>}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      d.youthShapedSuggestions && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Youth-shaped ideas</h2>
          <div class={PROSE} set:html={youthHtml} />
        </section>
      )
    }

    {
      related.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-lg font-bold text-slate-900">Related badges</h2>
          <ul class="flex flex-wrap gap-2">
            {related.map((r) => (
              <li>
                <a
                  href={r.href}
                  class="rounded-full bg-scout-purple/10 px-3 py-1 text-sm text-scout-purple-dark hover:bg-scout-purple/20"
                  {...(r.external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {r.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <footer class="mt-12 border-t border-slate-200 pt-6 text-sm text-slate-500">
      {d.supportedBy?.title && <p>Supported by {d.supportedBy.title}.</p>}
      <p class="mt-1">
        Version {d.versionDate}.{' '}
        <a
          href={d.sourceUrl}
          class="text-scout-purple hover:underline"
          target="_blank"
          rel="noopener"
        >
          Source on scouts.org.uk
        </a>
      </p>
    </footer>
  </main>
</Base>
