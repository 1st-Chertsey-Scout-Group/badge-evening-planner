---
import Base from '@/layouts/Base.astro'
---

<Base title="Page not found - Badge Tracker">
  <main class="mx-auto max-w-md px-4 py-20 text-center">
    <p class="text-5xl font-bold text-scout-purple">404</p>
    <h1 class="mt-3 text-xl font-semibold text-slate-800">Page not found</h1>
    <p class="mt-2 text-slate-600">That badge or page doesn't exist.</p>
    <a
      href="/"
      class="mt-6 inline-block rounded-lg bg-scout-purple px-4 py-2 font-medium text-white hover:bg-scout-purple-dark"
    >
      Browse badges
    </a>
  </main>
</Base>
