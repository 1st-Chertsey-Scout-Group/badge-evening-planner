---
import { getCollection, render } from 'astro:content'
import Base from '@/layouts/Base.astro'
import PlanToggle from '@/components/PlanToggle'
import { resolveBase } from '@/lib/bases'
import { PROSE } from '@/lib/prose'
import { ArrowLeft, Clock } from 'lucide-preact'

export async function getStaticPaths() {
  const bases = await getCollection('bases')
  return bases.map((base) => ({ params: { slug: base.id }, props: { base } }))
}

const { base } = Astro.props
const resolved = await resolveBase(base)
const { Content } = await render(base)

const byBadge = new Map<string, { title: string; reqs: string[] }>()
for (const c of resolved.covers) {
  const e = byBadge.get(c.badgeSlug)
  if (e) e.reqs.push(c.reqTitle)
  else byBadge.set(c.badgeSlug, { title: c.badgeTitle, reqs: [c.reqTitle] })
}
const badges = [...byBadge.entries()]
---

<Base title={`${resolved.title} - Bases`} description={resolved.description}>
  <main class="mx-auto max-w-3xl px-4 py-8">
    <a href="/bases" class="inline-flex items-center gap-1 text-sm text-scout-purple hover:underline">
      <ArrowLeft size={16} /> All bases
    </a>

    <header class="mt-4 flex flex-wrap items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">{resolved.title}</h1>
        {resolved.description && <p class="mt-1 text-slate-600">{resolved.description}</p>}
        <p class="mt-2 inline-flex items-center gap-1.5 text-sm text-slate-500">
          <Clock size={15} /> {resolved.duration} min
        </p>
      </div>
      <PlanToggle client:load slug={resolved.slug} />
    </header>

    {
      resolved.tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {resolved.tags.map((t) => (
            <li class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
              {t}
            </li>
          ))}
        </ul>
      )
    }

    <section class="mt-6 rounded-xl border border-slate-200 bg-white p-5">
      <h2 class="font-semibold text-slate-800">Completes</h2>
      <ul class="mt-3 space-y-4">
        {
          badges.map(([slug, b]) => (
            <li>
              <a
                href={`/badges/${slug}`}
                class="font-medium text-scout-purple hover:underline"
              >
                {b.title}
              </a>
              <ul class="mt-1 list-disc space-y-1 pl-5 text-sm text-slate-600">
                {b.reqs.map((r) => (
                  <li>{r}</li>
                ))}
              </ul>
            </li>
          ))
        }
      </ul>
    </section>

    {
      resolved.equipment.length > 0 && (
        <section class="mt-6 rounded-xl border border-slate-200 bg-white p-5">
          <h2 class="font-semibold text-slate-800">Equipment</h2>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-slate-600">
            {resolved.equipment.map((e) => (
              <li>{e}</li>
            ))}
          </ul>
        </section>
      )
    }

    <article class={`mt-6 ${PROSE}`}>
      <Content />
    </article>
  </main>
</Base>
